# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local           # local | s3 (s3 not yet implemented)
STORAGE_ROOT=/app/data/projects # path to project storage root (local only)
# S3_BUCKET=my-bucket           # s3 only
# S3_PREFIX=vc/                 # s3 only

# ── Queue / cache ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── API config ────────────────────────────────────────────────────────────────
CONFIG_PATH=/app/config/default.yaml

# ── VLM ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── LLM providers (add whichever you use) ────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

HOST_STORAGE_ROOT=your-path-to-projects

# ── Langfuse LLM tracing (optional) ──────────────────────────────────────────
# Leave unset to disable tracing entirely.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com